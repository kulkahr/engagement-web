{
  "applicationMetadata": {
    "name": "Maharashtrian साखरपुडा (Engagement) Invitation Web Application",
    "type": "Engagement Invitation Platform",
    "purpose": "Elegant digital platform for managing engagement ceremony invitations with RSVP, venue details, gallery, and blessings",
    "theme": "Botanical Maharashtrian Minimal",
    "themeVersion": "2.0",
    "description": "Inspired by traditional Maharashtrian Sakharpuda invitation cards featuring ivory paper, banana leaves, lotus flowers, sacred motifs, and elegant typography.",
    "targetAudience": "Indian families, guests from diverse tech backgrounds",
    "language": "Bilingual (Marathi + English)",
    "framework": "SvelteKit 2.x with TypeScript",
    "styling": "Vanilla CSS with CSS Custom Properties",
    "deployment": "Static (Vercel/Cloudflare Pages)"
  },
  "designSystem": {
