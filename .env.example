# ═══════════════════════════════════════════════════════════
# Environment Variables — साखरपुडा Engagement Invitation
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in YOUR actual values:
#   cp .env.example .env
#
# The PUBLIC_* vars below contain placeholder values.
# Replace them with your real event details.
#
# ⚠️ NEVER commit the actual .env file to git (it's in .gitignore).
# ═══════════════════════════════════════════════════════════

# ── Couple Names (JSON) ──────────────────────────────────
PUBLIC_COUPLE={"groom":{"name":"[GROOM_NAME_MR]","nameEn":"[GROOM_NAME_EN]","father":"[GROOM_FATHER_MR]","mother":"[GROOM_MOTHER_MR]"},"bride":{"name":"[BRIDE_NAME_MR]","nameEn":"[BRIDE_NAME_EN]","father":"[BRIDE_FATHER_MR]","mother":"[BRIDE_MOTHER_MR]"}}

# ── Venue / Location (JSON) ──────────────────────────────
PUBLIC_VENUE={"name":"[VENUE_NAME_MR]","nameEn":"[VENUE_NAME_EN]","address":"[VENUE_ADDRESS_MR]","addressEn":"[VENUE_ADDRESS_EN]","city":"[VENUE_CITY_MR]","cityEn":"[VENUE_CITY_EN]","pincode":"000000","coordinates":{"lat":0,"lng":0},"whatsappLocation":"[VENUE_NAME_EN]"}

# ── Map Links (JSON) ─────────────────────────────────────
PUBLIC_MAP_LINKS={"google":"","apple":"","mappls":""}

# ── Event Details (JSON) ─────────────────────────────────
PUBLIC_EVENT={"type":"साखरपुडा","typeEn":"Engagement (Sakharpuda)","date":"2026-01-01","time":"00:00","timeEn":"12:00 AM","panchang":"[PANCHANG_MR]","panchangEn":"[PANCHANG_EN]"}

# ── Event Schedule Timings (JSON array) ──────────────────
PUBLIC_TIMINGS=[{"label":"[TIMING_1_MR]","labelEn":"[TIMING_1_EN]","time":"--:--","timeEn":"--:--"},{"label":"[TIMING_2_MR]","labelEn":"[TIMING_2_EN]","time":"--:--","timeEn":"--:--"},{"label":"[TIMING_3_MR]","labelEn":"[TIMING_3_EN]","time":"--:--","timeEn":"--:--"}]

# ── Contacts (JSON array) ────────────────────────────────
PUBLIC_CONTACTS=[{"name":"[CONTACT_1_NAME_MR]","nameEn":"[CONTACT_1_NAME_EN]","relationship":"[CONTACT_1_REL_MR]","relationshipEn":"[CONTACT_1_REL_EN]"},{"name":"[CONTACT_2_NAME_MR]","nameEn":"[CONTACT_2_NAME_EN]","relationship":"[CONTACT_2_REL_MR]","relationshipEn":"[CONTACT_2_REL_EN]"}]

# ── Google Drive (JSON) ──────────────────────────────────
PUBLIC_DRIVE={"folderUrl":"","folderId":""}

# ── RSVP Deadline Dates ──────────────────────────────────
PUBLIC_RSVP_DEADLINE_MR=१ ऑगस्ट २०२६
PUBLIC_RSVP_DEADLINE_EN=August 1, 2026

# ── Footer Hosts (family names) ───────────────────────────
PUBLIC_FOOTER_HOSTS_MR=कुलकर्णी आणि काळे कुटुंब
PUBLIC_FOOTER_HOSTS_EN=Kulkarni & Kale Families

# ── Image Paths ──────────────────────────────────────────
# Paths to key site images. Can be relative (/images/...) or absolute URLs (CDN).
# Defaults are used if not set.
PUBLIC_IMAGE_MONOGRAM=/images/monogram.webp
PUBLIC_IMAGE_MONOGRAM_FALLBACK=/images/monogram.png
PUBLIC_IMAGE_OG=/images/og-image.svg

# ── Contact Phone Numbers ────────────────────────────────
PUBLIC_PHONE_GROOM_FATHER=+91-XXXXXXXXXX
PUBLIC_PHONE_BRIDE_FATHER=+91-XXXXXXXXXX

# ── Vercel Blob ──
BLOB_READ_WRITE_TOKEN=

# ── Admin Password ──
RSVP_ADMIN_SECRET=

# ── Google Drive API Key (optional) ──
GOOGLE_DRIVE_API_KEY=
